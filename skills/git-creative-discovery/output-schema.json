{
  "type": "object",
  "required": ["project", "scan_lines", "creative_points", "final_report_markdown"],
  "properties": {
    "project": {
      "type": "object",
      "required": ["name", "summary", "main_languages", "frameworks"]
    },
    "scan_lines": {
      "type": "array"
    },
    "creative_points": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "title",
          "innovation_type",
          "innovation_layer",
          "score",
          "traditional_approach",
          "new_approach",
          "description",
          "plain_explanation",
          "application_scenarios",
          "evidence",
          "moveable_domains"
        ]
      }
    },
    "final_report_markdown": {
      "type": "string"
    }
  }
}
