{
  "type": "object",
  "required": ["project", "scan_lines", "creative_points", "final_report_markdown"],
  "properties": {
    "project": {
      "type": "object",
      "required": ["name", "summary", "main_languages", "frameworks"]
    },
    "scan_lines": {
      "type": "array"
    },
    "creative_points": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "title",
          "innovation_type",
          "innovation_layer",
          "score",
          "traditional_approach",
          "new_approach",
          "description",
          "plain_explanation",
          "application_scenarios",
          "evidence",
          "moveable_domains"
        ],
        "properties": {
          "application_scenarios": {
            "type": "array",
            "minItems": 3,
            "items": {
              "type": "object",
              "required": ["name", "description"],
              "properties": {
                "name": {
                  "type": "string",
                  "description": "真实具体的场景标题，不要写泛泛行业名。"
                },
                "description": {
                  "type": "string",
                  "description": "说明谁遇到什么问题、这个创意点怎么用、带来什么价值。"
                }
              }
            }
          }
        }
      }
    },
    "final_report_markdown": {
      "type": "string"
    }
  }
}
