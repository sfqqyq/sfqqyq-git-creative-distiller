# 后端服务
APP_NAME=sfqqyq-git-creative-distiller
APP_ENV=local
DATABASE_URL=sqlite:///./data/app.db
WORKSPACE_DIR=./storage/repos
SKILL_PATH=../skills/git-creative-discovery/SKILL.md

# Claude Code
# 未配置时，系统会使用演示分析结果，方便本地先跑通流程。
CLAUDE_COMMAND=claude
ANTHROPIC_API_KEY=
ENABLE_CLAUDE=false

# DeepSeek 接入 Claude Code
# 按 DeepSeek 文档配置。填好 ANTHROPIC_AUTH_TOKEN 后，把 ENABLE_CLAUDE 改成 true。
ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_MODEL=deepseek-v4-pro[1m]
ANTHROPIC_DEFAULT_OPUS_MODEL=deepseek-v4-pro[1m]
ANTHROPIC_DEFAULT_SONNET_MODEL=deepseek-v4-pro[1m]
ANTHROPIC_DEFAULT_HAIKU_MODEL=deepseek-v4-flash
CLAUDE_CODE_SUBAGENT_MODEL=deepseek-v4-flash
CLAUDE_CODE_EFFORT_LEVEL=max

# 前端访问后端地址
VITE_API_BASE_URL=http://127.0.0.1:8000
