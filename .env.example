# 后端服务
APP_NAME=sfqqyq-git-creative-distiller
APP_ENV=local
# 本地开发可临时使用 SQLite；服务器部署推荐 PostgreSQL。
DATABASE_URL=sqlite:///./data/app.db
# DATABASE_URL=postgresql+psycopg2://git_creative_distiller:password@postgres:5432/git_creative_distiller
WORKSPACE_DIR=./storage/repos
SKILL_PATH=../skills/git-creative-discovery/SKILL.md
# 国内服务器访问 GitHub 慢或超时时，可以配置克隆加速前缀。
# 例如输入 git@github.com:owner/repo.git 时，会转成 https://ghfast.top/https://github.com/owner/repo.git
GITHUB_CLONE_PROXY=

# 登录保护。服务器部署时必须配置强密码和随机会话密钥。
AUTH_USERNAME=admin
AUTH_PASSWORD=
AUTH_SESSION_SECRET=
# 默认会话有效期 7 天。
AUTH_SESSION_SECONDS=604800
# 如果前端使用 HTTPS 访问，可以改成 true。
AUTH_COOKIE_SECURE=false

# MiniMax 文生图。用于给每个创意点生成本地保存的释义图。
MINIMAX_API_KEY=
MINIMAX_API_BASE_URL=https://api.minimax.io/v1
MINIMAX_IMAGE_MODEL=image-01
MINIMAX_IMAGE_ASPECT_RATIO=16:9
IMAGE_OUTPUT_DIR=./storage/images
IMAGE_URL_PREFIX=/generated-images

# Claude Code
# 未配置时，系统会使用演示分析结果，方便本地先跑通流程。
CLAUDE_COMMAND=claude
ANTHROPIC_API_KEY=
ENABLE_CLAUDE=false

# DeepSeek 接入 Claude Code
# 按 DeepSeek 文档配置。填好 ANTHROPIC_AUTH_TOKEN 后，把 ENABLE_CLAUDE 改成 true。
ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_MODEL=deepseek-v4-pro[1m]
ANTHROPIC_DEFAULT_OPUS_MODEL=deepseek-v4-pro[1m]
ANTHROPIC_DEFAULT_SONNET_MODEL=deepseek-v4-pro[1m]
ANTHROPIC_DEFAULT_HAIKU_MODEL=deepseek-v4-flash
CLAUDE_CODE_SUBAGENT_MODEL=deepseek-v4-flash
CLAUDE_CODE_EFFORT_LEVEL=max

# 前端访问后端地址
VITE_API_BASE_URL=http://127.0.0.1:8000
